interface counter_if(input logic clk, rst_n);
  
  logic en;
  logic [3:0] count;
  
  clocking cb @(posedge clk);  
   default input #1 output #1.5;
    input [3:0] count;
    output en;
  endclocking
  
  
  modport dut(input clk,rst_n,en, output count );  
  modport testb(clocking cb);
endinterface
  
  
